---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Experience from "../components/Experience.astro";
import Education from "../components/Education.astro";
import Map from "../components/Map.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<title>Zhi Yang Chen</title>
		<meta
			name="description"
			content="Personal site of Zhi Yang Chen — Software Development Engineer 2 at AMD, working on GPU driver validation and automation."
		/>
		<link rel="canonical" href={Astro.site} />

		<meta property="og:site_name" content="Zhi Yang Chen" />
		<meta property="og:title" content="Zhi Yang Chen" />
		<meta property="og:url" content={Astro.site} />
		<meta
			property="og:description"
			content="Personal site of Zhi Yang Chen — Software Development Engineer 2 at AMD, working on GPU driver validation and automation."
		/>
		<meta property="og:type" content="website" />
		<meta property="og:image" content={new URL("/og.jpg", Astro.site)} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Zhi Yang Chen" />
		<meta
			name="twitter:description"
			content="Personal site of Zhi Yang Chen — Software Development Engineer 2 at AMD, working on GPU driver validation and automation."
		/>
		<meta name="twitter:image" content={new URL("/og.jpg", Astro.site)} />

		<script is:inline>
			const stored = localStorage.getItem("theme");
			const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
			if (stored === "dark" || (!stored && prefersDark)) {
				document.documentElement.classList.add("dark");
			}
		</script>
	</head>
	<body class="bg-stone-50 text-stone-800 dark:bg-slate-900 dark:text-slate-100">
		<div class="fixed right-4 top-4 z-10">
			<ThemeToggle />
		</div>
		<main class="mx-auto max-w-3xl">
			<Header />
			<Map />
			<Experience />
			<Education />
		</main>
		<Footer />
	</body>
</html>
