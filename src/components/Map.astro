---
import "leaflet/dist/leaflet.css";
import { locations } from "../data/locations";
---

<section class="mx-auto max-w-3xl px-6 py-8 sm:py-10">
	<p class="mb-3 text-xs font-medium uppercase tracking-wide text-stone-400 dark:text-stone-500">Where I've worked, on a map</p>
	<div id="gta-map" class="h-72 w-full rounded-lg border border-stone-200 sm:h-80 lg:h-96 dark:border-stone-700" data-locations={JSON.stringify(locations)}></div>
</section>

<script>
	import L from "leaflet";
	import type { OfficeLocation } from "../data/locations";

	const el = document.getElementById("gta-map")!;
	const locations = JSON.parse(el.dataset.locations ?? "[]") as OfficeLocation[];

	// On touch devices, one-finger drag would hijack page scrolling, so disable
	// panning there and let the zoom buttons handle interaction instead.
	const isTouch = L.Browser.mobile;
	const map = L.map(el, {
		scrollWheelZoom: false,
		zoomControl: false,
		attributionControl: false,
		dragging: !isTouch,
	}).setView([43.74, -79.45], 10);
	L.control.attribution({ prefix: false }).addTo(map);

	const ZoomControl = L.Control.extend({
		options: { position: "topleft" },
		onAdd() {
			const container = L.DomUtil.create(
				"div",
				"flex flex-col overflow-hidden rounded-md border border-stone-300 bg-white shadow-sm dark:border-stone-600 dark:bg-stone-800",
			);
			const makeButton = (label: string, symbol: string, onClick: () => void) => {
				const button = L.DomUtil.create(
					"button",
					"flex h-9 w-9 items-center justify-center text-lg font-medium leading-none text-stone-700 hover:bg-stone-100 sm:h-7 sm:w-7 sm:text-base dark:text-stone-200 dark:hover:bg-stone-700",
					container,
				);
				button.type = "button";
				button.setAttribute("aria-label", label);
				button.textContent = symbol;
				L.DomEvent.on(button, "click", L.DomEvent.stop).on(button, "click", onClick);
			};
			makeButton("Zoom in", "+", () => map.zoomIn());
			makeButton("Zoom out", "−", () => map.zoomOut());
			L.DomEvent.disableClickPropagation(container);
			L.DomEvent.disableScrollPropagation(container);
			return container;
		},
	});
	new ZoomControl().addTo(map);

	const lightTiles = "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png";
	const darkTiles = "https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png";
	const isDark = () => document.documentElement.classList.contains("dark");

	const tileLayer = L.tileLayer(isDark() ? darkTiles : lightTiles, {
		attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
		maxZoom: 19,
	}).addTo(map);

	const currentColorLight = "#4f46e5";
	const currentColorDark = "#a5b4fc";
	const pastColor = "#a8a29e";

	const makeIcon = (current?: boolean) => {
		const size = current ? 16 : 10;
		const color = current ? (isDark() ? currentColorDark : currentColorLight) : pastColor;
		return L.divIcon({
			className: "",
			html: `
				<span class="relative flex" style="width: ${size}px; height: ${size}px">
					${current ? `<span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-50" style="background-color: ${color}"></span>` : ""}
					<span class="relative block rounded-full ring-2 ring-white" style="width: ${size}px; height: ${size}px; background-color: ${color}"></span>
				</span>
			`,
			iconSize: [size, size],
			iconAnchor: [size / 2, size / 2],
		});
	};

	const markers = locations.map((loc) => {
		const marker = L.marker([loc.lat, loc.lng], { icon: makeIcon(loc.current) }).addTo(map);
		if (loc.current) {
			marker.bindTooltip(`<strong>${loc.name}</strong><br/>${loc.role}`, {
				permanent: true,
				direction: "top",
				offset: [0, -12],
				className: "location-tooltip",
			});
		} else {
			marker.bindPopup(`<strong>${loc.name}</strong><br/>${loc.role}`);
		}
		return { marker, loc };
	});

	new MutationObserver(() => {
		tileLayer.setUrl(isDark() ? darkTiles : lightTiles);
		markers.forEach(({ marker, loc }) => marker.setIcon(makeIcon(loc.current)));
	}).observe(document.documentElement, {
		attributes: true,
		attributeFilter: ["class"],
	});

	if (markers.length) {
		map.fitBounds(L.featureGroup(markers.map(({ marker }) => marker)).getBounds(), {
			paddingTopLeft: [32, 60],
			paddingBottomRight: [32, 32],
		});
	}
</script>
