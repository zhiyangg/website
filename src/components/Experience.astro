---
import { Image } from "astro:assets";
import { current, previous } from "../data/experience";

const entries = [{ ...current, label: "Currently" }, ...previous.map((p) => ({ ...p, label: "Previously" }))];
---

<section class="mx-auto max-w-3xl px-6 py-10">
	<div class="flex flex-col divide-y divide-stone-200 dark:divide-stone-700">
		{entries.map((entry, i) => (
			<a
				href={entry.companyLink}
				target="_blank"
				rel="noopener noreferrer"
				class="group flex items-start gap-4 py-6 first:pt-0 last:pb-0"
			>
				<Image
					src={entry.logo}
					alt={entry.company}
					width={80}
					height={80}
					class="mt-1 h-10 w-10 shrink-0 rounded-md object-contain"
				/>
				<div class="flex-1">
					{(i === 0 || entries[i - 1].label !== entry.label) && (
						<p class:list={[
							"mb-1 text-xs font-medium uppercase tracking-wide",
							entry.label === "Currently"
								? "text-indigo-600 dark:text-indigo-300"
								: "text-stone-400 dark:text-stone-500",
						]}>{entry.label}</p>
					)}
					<p class="font-medium text-stone-900 group-hover:text-terracotta-600 dark:text-stone-50 dark:group-hover:text-terracotta-400">{entry.title}</p>
					<p class="text-xs text-stone-400 dark:text-stone-500">{entry.company} · {entry.date}</p>
					<p class="mt-1.5 text-sm leading-relaxed text-stone-600 dark:text-stone-300">{entry.summary}</p>
					<p class="mt-1.5 text-xs text-stone-400 dark:text-stone-500">{entry.technologies}</p>
				</div>
			</a>
		))}
	</div>
</section>
