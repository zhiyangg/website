---
import EntryCard from "./EntryCard.astro";
import { current, previous } from "../data/experience";

const entries = [{ ...current, label: "Currently" }, ...previous.map((p) => ({ ...p, label: "Previously" }))];
---

<section class="mx-auto max-w-3xl px-6 py-8 sm:py-10">
	<div class="flex flex-col divide-y divide-stone-200 dark:divide-stone-700">
		{entries.map((entry, i) => {
			// Show the group label only on the first entry of each run, so
			// "Currently" and "Previously" each appear once.
			const showLabel = i === 0 || entries[i - 1].label !== entry.label;
			return (
				<EntryCard
					href={entry.companyLink}
					logo={entry.logo}
					logoWidth={80}
					logoHeight={80}
					title={entry.title}
					subtitle={entry.company}
					date={entry.date}
					summary={entry.summary}
					technologies={entry.technologies}
					label={showLabel ? entry.label : undefined}
					labelClass={entry.label === "Currently"
						? "text-indigo-600 dark:text-indigo-300"
						: "text-stone-400 dark:text-stone-500"}
					class="py-6 first:pt-0 last:pb-0"
				/>
			);
		})}
	</div>
</section>
