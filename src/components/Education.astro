---
import EntryCard from "./EntryCard.astro";
import uoftIcon from "../assets/logos/uoft-icon.png";
---

<section class="mx-auto max-w-3xl px-6 py-8 sm:py-10">
	<h2 class="mb-3 text-xs font-medium uppercase tracking-wide text-stone-400 dark:text-stone-500">Education</h2>
	<!-- The UofT logo is portrait (195×373), not square like the other logos, so
	     we pass only logoWidth and let Astro derive the height from the source
	     aspect ratio — forcing a square height would distort the generated image.
	     object-contain then fits it into the h-10 w-10 box. Leave height off. -->
	<EntryCard
		href="https://www.ece.utoronto.ca/"
		logo={uoftIcon}
		logoWidth={160}
		title="Computer Engineering"
		subtitle="University of Toronto"
		date="2021 - 2026"
		summary="Minor in Artificial Intelligence Engineering"
	/>
</section>
